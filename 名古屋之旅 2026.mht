@charset "utf-8";

:root { --sakura: #f9b4c0; --sakura-l: #fff0f3; --rose: #d44f6a; --amber: #f5a623; --green: #4aad8a; --blue: #3a7ec2; --purple: #8a6fd4; --ink: #22201e; --muted: #756e68; --line: #ede4df; --bg: #fdf8f6; --card: #ffffff; --shadow: 0 4px 20px rgba(80,30,40,.09); --r: 16px; --nav-h: 62px; --safe-b: env(safe-area-inset-bottom,0px); }

* { box-sizing: border-box; -webkit-tap-highlight-color: transparent; margin: 0px; padding: 0px; }

html, body { height: 100%; background: var(--bg); }

body { font-family: -apple-system, BlinkMacSystemFont, "PingFang TC", "Noto Sans TC", sans-serif; color: var(--ink); line-height: 1.55; overscroll-behavior: none; }

button { cursor: pointer; font-family: inherit; }

a { color: inherit; text-decoration: none; }

#app { display: flex; flex-direction: column; height: 100dvh; max-width: 600px; margin: 0px auto; position: relative; }

#top-bar { flex: 0 0 auto; background: linear-gradient(160deg, rgb(255, 245, 240), rgb(255, 240, 245)); border-bottom: 1px solid var(--line); padding: 14px 16px 0px; }

#top-bar h1 { font-size: 21px; letter-spacing: -0.3px; margin-bottom: 3px; }

.info-row { display: flex; gap: 7px; flex-wrap: wrap; padding: 6px 0px 0px; }

.info-pill { background: rgb(255, 255, 255); border: 1px solid var(--line); border-radius: 999px; padding: 4px 10px; font-size: 11.5px; color: var(--muted); }

.info-pill b { color: var(--rose); }

#day-bar { display: flex; gap: 6px; overflow-x: auto; padding: 10px 16px 11px; background: linear-gradient(160deg, rgb(255, 245, 240), rgb(255, 240, 245)); scrollbar-width: none; }

#day-bar::-webkit-scrollbar { display: none; }

.day-tab { flex: 0 0 auto; padding: 7px 13px; border-radius: 999px; border: 1.5px solid var(--line); background: rgb(255, 255, 255); font-size: 12px; font-weight: 700; color: var(--muted); transition: 0.2s; line-height: 1.3; text-align: center; }

.day-tab.active { background: var(--rose); border-color: var(--rose); color: rgb(255, 255, 255); }

#content { flex: 1 1 0px; overflow-y: auto; padding-bottom: calc(var(--nav-h) + var(--safe-b) + 8px); }

.screen { display: none; padding: 12px 13px 4px; }

.screen.visible { display: block; }

.notice { background: linear-gradient(135deg, rgb(255, 248, 225), rgb(255, 243, 230)); border: 1px solid rgb(245, 212, 154); border-radius: 12px; padding: 10px 13px; font-size: 13px; margin-bottom: 11px; color: rgb(90, 62, 0); }

.notice b { color: rgb(192, 96, 0); }

.notice.blue { background: linear-gradient(135deg, rgb(238, 244, 255), rgb(232, 240, 255)); border-color: rgb(184, 207, 255); color: rgb(26, 48, 104); }

.notice.blue b { color: rgb(26, 48, 104); }

.notice.green { background: linear-gradient(135deg, rgb(237, 250, 243), rgb(228, 247, 236)); border-color: rgb(160, 217, 188); color: rgb(13, 80, 48); }

.notice.green b { color: rgb(13, 80, 48); }

.notice.warn { background: linear-gradient(135deg, rgb(255, 240, 240), rgb(255, 232, 232)); border-color: rgb(249, 191, 191); color: rgb(122, 24, 32); }

.notice.warn b { color: rgb(154, 0, 16); }

.sec-title { font-size: 11.5px; font-weight: 700; letter-spacing: 0.7px; color: var(--muted); text-transform: uppercase; margin: 14px 3px 7px; }

.tl-card { background: var(--card); border: 1px solid var(--line); border-radius: var(--r); box-shadow: var(--shadow); margin-bottom: 9px; overflow: hidden; }

.tl-head { display: grid; grid-template-columns: 72px 1fr 30px; align-items: stretch; }

.tl-time { background: var(--sakura-l); border-right: 2px solid var(--sakura); display: flex; align-items: center; justify-content: center; font-size: 11.5px; font-weight: 700; color: var(--rose); padding: 12px 5px; text-align: center; line-height: 1.3; }

.tl-body { padding: 11px 10px 10px; }

.tl-body b { display: block; font-size: 14px; margin-bottom: 3px; line-height: 1.35; }

.tl-body p { font-size: 12.5px; color: var(--muted); line-height: 1.4; }

.tl-toggle { display: flex; align-items: center; justify-content: center; padding-right: 6px; color: rgb(221, 221, 221); font-size: 18px; transition: transform 0.2s; }

.tl-card.has-detail .tl-toggle { color: var(--rose); }

.tl-card.open .tl-toggle { transform: rotate(90deg); }

.tl-detail { display: none; border-top: 1px solid var(--line); background: rgb(253, 250, 249); padding: 10px 13px 12px; }

.tl-card.open .tl-detail { display: block; }

.tl-detail ul { padding-left: 17px; margin: 4px 0px 0px; }

.tl-detail li { font-size: 12.5px; color: var(--muted); margin: 5px 0px; line-height: 1.4; }

.tl-detail li b { color: var(--ink); font-size: 12.5px; }

.map-btn { display: inline-flex; align-items: center; gap: 5px; margin-top: 8px; padding: 6px 13px; background: var(--blue); color: rgb(255, 255, 255); border-radius: 999px; font-size: 12px; font-weight: 600; border: none; box-shadow: rgba(40, 80, 160, 0.2) 0px 2px 8px; }

.map-btn span { font-size: 14px; }

.badge-row { display: flex; flex-wrap: wrap; gap: 5px; margin-top: 6px; }

.badge { display: inline-block; padding: 3px 9px; border-radius: 999px; font-size: 11px; font-weight: 600; }

.b-food { background: rgb(255, 240, 230); color: rgb(176, 64, 0); }

.b-sakura { background: rgb(255, 240, 244); color: rgb(176, 48, 96); }

.b-car { background: rgb(238, 244, 255); color: rgb(26, 85, 176); }

.b-free { background: rgb(240, 250, 244); color: rgb(26, 122, 80); }

.b-warn { background: rgb(255, 248, 230); color: rgb(144, 80, 0); }

.b-alt { background: rgb(245, 240, 255); color: rgb(80, 48, 160); }

.b-shop { background: rgb(255, 245, 224); color: rgb(128, 64, 0); }

.b-hotel { background: rgb(232, 244, 255); color: rgb(16, 64, 128); }

.hotel-card { background: var(--card); border: 1px solid var(--line); border-radius: var(--r); box-shadow: var(--shadow); margin-bottom: 10px; overflow: hidden; }

.hotel-head { display: flex; align-items: center; gap: 11px; padding: 12px 13px; }

.hotel-icon { width: 44px; height: 44px; border-radius: 12px; background: rgb(238, 244, 255); display: flex; align-items: center; justify-content: center; font-size: 22px; flex: 0 0 44px; }

.hotel-info h3 { font-size: 14.5px; margin-bottom: 2px; }

.hotel-info p { font-size: 12px; color: var(--muted); }

.hotel-addr { padding: 0px 13px 12px; font-size: 12px; color: var(--muted); line-height: 1.5; }

.rest-card { background: var(--card); border: 1px solid var(--line); border-radius: var(--r); box-shadow: var(--shadow); margin-bottom: 11px; overflow: hidden; }

.rest-head { display: flex; align-items: center; gap: 12px; padding: 12px 13px 9px; }

.rest-icon { width: 46px; height: 46px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 23px; flex: 0 0 46px; }

.rest-info h3 { font-size: 14.5px; margin-bottom: 2px; }

.rest-info p { font-size: 12px; color: var(--muted); }

.rest-tags { display: flex; flex-wrap: wrap; gap: 5px; padding: 0px 13px 9px; }

.rest-tag { background: var(--sakura-l); border: 1px solid var(--sakura); color: var(--rose); padding: 3px 10px; border-radius: 999px; font-size: 11.5px; }

.rest-note { border-top: 1px solid var(--line); background: rgb(253, 250, 249); padding: 9px 13px; font-size: 12.5px; color: var(--muted); }

.check-section h3 { font-size: 14px; margin: 14px 0px 8px; padding-left: 8px; border-left: 3px solid var(--rose); font-weight: 700; }

.check-wrap { background: var(--card); border: 1px solid var(--line); border-radius: var(--r); box-shadow: var(--shadow); overflow: hidden; margin-bottom: 4px; }

.ci { display: flex; align-items: flex-start; gap: 12px; padding: 11px 13px; border-bottom: 1px solid var(--line); }

.ci:last-child { border-bottom: none; }

.cbox { width: 22px; height: 22px; border-radius: 6px; border: 2px solid var(--line); flex: 0 0 22px; display: flex; align-items: center; justify-content: center; font-size: 13px; color: transparent; transition: 0.2s; margin-top: 1px; }

.ci.done .cbox { background: var(--green); border-color: var(--green); color: rgb(255, 255, 255); }

.ci.done .clabel { text-decoration: line-through; color: var(--muted); }

.clabel { font-size: 13.5px; line-height: 1.4; }

.csub { font-size: 11.5px; color: var(--muted); margin-top: 2px; }

#nav { position: fixed; bottom: 0px; left: 50%; transform: translateX(-50%); width: 100%; max-width: 600px; display: flex; background: rgba(255, 250, 248, 0.94); backdrop-filter: blur(14px); border-top: 1px solid var(--line); height: var(--nav-h); padding-bottom: var(--safe-b); z-index: 100; }

.nb { flex: 1 1 0%; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 3px; border: none; background: transparent; color: var(--muted); font-size: 10px; font-family: inherit; transition: color 0.15s; }

.nb .ni { font-size: 21px; line-height: 1; }

.nb.active { color: var(--rose); }

.sakura-bar { height: 6px; border-radius: 999px; background: linear-gradient(90deg,var(--sakura),var(--rose)); margin: 6px 0px; }

.date-row { display: flex; justify-content: space-between; font-size: 11px; color: var(--muted); }
